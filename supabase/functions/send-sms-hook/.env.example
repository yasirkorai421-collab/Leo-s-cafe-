# ─── Supabase Send SMS Hook — Environment Variables ──────────────────────────
# Copy this file to .env and fill in real values for local development.
# NEVER commit the .env file — only .env.example is safe to commit.

# Supabase Auth Hook signing secret
# Get from: Supabase Dashboard → Auth → Hooks → Send SMS → Signing Secret
# Format: v1,whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEND_SMS_HOOK_SECRET=v1,whsec_your_hook_secret_here

# ─── Pakistani SMS Gateway ───────────────────────────────────────────────────
# Replace with your chosen provider's API endpoint and key.
# Examples:
#   SendSMSGate:   https://sendsmsgate.com/api/v1/send
#   otpsmsapi.com: https://otpsmsapi.com/api/send
#   ExpertTexting:  https://www.experttexting.com/exaboroern/api/send
#   MSG91:          https://control.msg91.com/api/v5/flow/

GATEWAY_API_URL=https://your-gateway.com/api/send
GATEWAY_API_KEY=your_api_key_here
