# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Connection pooling URL (used by Prisma at runtime via pgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct URL (used by Prisma for migrations — bypasses pgBouncer)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Supabase Authentication ──────────────────────────────────────────────────
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to client - only for server-side admin operations like creating users)
# Get from Supabase: Settings > API > service_role key (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Supabase webhook secret (for syncing auth.users to your Prisma DB)
SUPABASE_WEBHOOK_SECRET=your-webhook-secret

# ─── SMS/OTP Services ────────────────────────────────────────────────────────
# Pay-as-you-go SMS delivery for OTP verification.
# Recommended: MSG91 for Pakistan, or Twilio as a fallback.
# Get from: https://msg91.com or https://console.twilio.com
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=LEOCAFE

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Cloudinary (Payment screenshot uploads) ─────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Upstash Redis (Rate limiting) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Payment Details (Admin-configurable) ─────────────────────────────────────
# JazzCash / Easypaisa / Bank account shown on payment page
PAYMENT_JAZZCASH_NUMBER=03XX-XXXXXXX
PAYMENT_EASYPAISA_NUMBER=03XX-XXXXXXX
PAYMENT_BANK_NAME=HBL
PAYMENT_BANK_ACCOUNT=1234567890
PAYMENT_BANK_IBAN=PK00XXXX0000000000000000
PAYMENT_WHATSAPP_NUMBER=923XXXXXXXXX

# ─── Dine-In QR (HMAC secret for signing QR tokens) ─────────────────────────
QR_SECRET=your-random-secret-min-32-chars

# ─── Cron Jobs (Vercel Cron secret) ──────────────────────────────────────────
CRON_SECRET=your-cron-secret

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Birthday Rewards ───────────────────────────────────────────────────────
BIRTHDAY_DISCOUNT=20
BIRTHDAY_MESSAGE="Enjoy your special day with Leo's Café! 🎂"

# ─── Loyalty Program ──────────────────────────────────────────────────────────
# Points per Rs. 100 spent
LOYALTY_POINTS_PER_100=10
# Points for Google review
GOOGLE_REVIEW_POINTS=200
