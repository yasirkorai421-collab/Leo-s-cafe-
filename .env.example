# ============================================================================
# LEO'S CAFE - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/leoscafe"
DIRECT_URL="postgresql://user:password@localhost:5432/leoscafe"

# ============================================================================
# SUPABASE AUTHENTICATION
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Webhook secret for Supabase Database Webhooks signature verification
# Generate with: openssl rand -base64 32
# Configure in: Supabase Dashboard → Database → Webhooks → HTTP Headers
SUPABASE_WEBHOOK_SECRET="your-webhook-secret-here"

# ============================================================================
# ADMIN CREDENTIALS (Pre-configured Admin Account)
# ============================================================================
# The admin will use these credentials to login directly
# No signup process required for admin
ADMIN_EMAIL="admin@leoscafe.com"
ADMIN_PASSWORD="your-secure-admin-password-here"
ADMIN_PHONE="+923001234567"
ADMIN_NAME="Admin"

# ============================================================================
# DELIVERY PERSONNEL CREDENTIALS
# ============================================================================
# Add delivery boys here - format: NAME|EMAIL|PASSWORD|PHONE (separated by semicolons)
# Example: "John Doe|john@leoscafe.com|password123|+923001111111;Jane Smith|jane@leoscafe.com|password456|+923002222222"
DELIVERY_PERSONNEL="Rider 1|rider1@leoscafe.com|rider1pass|+923001111111;Rider 2|rider2@leoscafe.com|rider2pass|+923002222222"

# ============================================================================
# SMS / OTP SERVICE (Choose one or both as fallback)
# ============================================================================
# HOST PHONE NUMBER - This number will be used to send OTP messages
HOST_PHONE_NUMBER="+923001234567"

# MSG91 Configuration (Indian/Pakistani SMS Service - RECOMMENDED for Pakistan)
MSG91_API_KEY="your-msg91-api-key"
MSG91_SENDER_ID="LEOCAFE"
MSG91_TEMPLATE_ID="your-template-id"

# Twilio Configuration (International SMS Service)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+15551234567"

# Generic SMS API (Optional - for local Pakistani SMS providers)
# Configure this if you have a custom SMS gateway
SMS_API_URL="https://your-sms-provider.com/api/send"
SMS_API_KEY="your-sms-api-key"
SMS_SENDER_ID="LEOCAFE"

# ============================================================================
# PAYMENT SETTINGS (Used in checkout and admin settings)
# ============================================================================
JAZZCASH_NUMBER="03001234567"
EASYPAISA_NUMBER="03001234567"
BANK_NAME="HBL"
BANK_ACCOUNT_NUMBER="1234567890123"
BANK_ACCOUNT_TITLE="Leo's Cafe"
WHATSAPP_NUMBER="923001234567"

# ============================================================================
# CLOUDINARY (For image uploads - payment proofs, menu items, stories)
# ============================================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================================================
# LOYALTY & REWARDS SETTINGS
# ============================================================================
# Points awarded per Rs spent
POINTS_PER_RS="1"
# Redemption rate (Rs per point)
REDEMPTION_RATE="1"
# Bonus points for Google review submission
REVIEW_BONUS_POINTS="50"

# ============================================================================
# BIRTHDAY REWARDS
# ============================================================================
BIRTHDAY_DISCOUNT="20"
BIRTHDAY_VALIDITY_DAYS="7"
BIRTHDAY_MESSAGE="Happy Birthday! Enjoy 20% off on your special day!"

# ============================================================================
# WIN-BACK CAMPAIGN
# ============================================================================
WINBACK_THRESHOLD_DAYS="30"
WINBACK_DISCOUNT="15"
WINBACK_VALIDITY_DAYS="14"
WINBACK_MESSAGE="We miss you! Come back and enjoy 15% off your order!"

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================================================
# CSRF PROTECTION
# ============================================================================
CSRF_SECRET="your-random-csrf-secret-key-min-32-chars"

# ============================================================================
# CRON JOB SECRET (For scheduled tasks like birthday wishes)
# ============================================================================
CRON_SECRET="your-secure-cron-secret-key"

# ============================================================================
# WHATSAPP ORDER CONFIRMATION SYSTEM
# ============================================================================
# WhatsApp server URL - where the standalone Node.js server runs
WHATSAPP_SERVER_URL="http://localhost:3001"

# Optional: Bearer token for webhook security (used by WhatsApp server callbacks)
WHATSAPP_CALLBACK_SECRET="your-whatsapp-callback-secret"

# Confirmation timeout in milliseconds (default: 5 minutes = 300000)
NEXT_PUBLIC_WHATSAPP_CONFIRMATION_TIMEOUT="300000"

# Next.js API URL for WhatsApp server to call back (used in production)
NEXT_JS_API_URL="http://localhost:3000"
