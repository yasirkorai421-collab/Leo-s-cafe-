# ============================================================================
# LEO'S CAFE - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# This file shows the required environment variables for Vercel deployment
# Add these in Vercel Dashboard > Settings > Environment Variables

# ============================================================================
# DATABASE (Supabase Postgres or Vercel Postgres)
# ============================================================================
DATABASE_URL="postgresql://user:password@your-db-host.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@your-db-host.supabase.co:5432/postgres"

# ============================================================================
# SUPABASE AUTHENTICATION
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-production-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-production-service-role-key"

# ============================================================================
# ADMIN & DELIVERY CREDENTIALS
# ============================================================================
ADMIN_EMAIL="admin@leoscafe.com"
ADMIN_PASSWORD="your-strong-production-password"
ADMIN_PHONE="+923361171626"
ADMIN_NAME="Leo's Cafe Admin"

DELIVERY_PERSONNEL="Rider1|rider1@leoscafe.com|securepass1|+923001111111"

# ============================================================================
# SMS SERVICE (MSG91 for Pakistan)
# ============================================================================
HOST_PHONE_NUMBER="+923361171626"
MSG91_API_KEY="your-production-msg91-key"
MSG91_SENDER_ID="LEOCAFE"
MSG91_TEMPLATE_ID="your-template-id"

# ============================================================================
# PAYMENT SETTINGS
# ============================================================================
JAZZCASH_NUMBER="03361171626"
EASYPAISA_NUMBER="03361171626"
BANK_NAME="HBL"
BANK_ACCOUNT_NUMBER="1234567890123"
BANK_ACCOUNT_TITLE="Leo's Cafe"
WHATSAPP_NUMBER="923361171626"

# ============================================================================
# CLOUDINARY
# ============================================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-production-cloud-name"
CLOUDINARY_API_KEY="your-production-api-key"
CLOUDINARY_API_SECRET="your-production-api-secret"

# ============================================================================
# LOYALTY SETTINGS
# ============================================================================
POINTS_PER_RS="1"
REDEMPTION_RATE="1"
REVIEW_BONUS_POINTS="50"
BIRTHDAY_DISCOUNT="20"
BIRTHDAY_VALIDITY_DAYS="7"
WINBACK_THRESHOLD_DAYS="30"
WINBACK_DISCOUNT="15"
WINBACK_VALIDITY_DAYS="14"

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NODE_ENV="production"

# ============================================================================
# SECURITY
# ============================================================================
CSRF_SECRET="production-csrf-secret-min-32-chars-random"
CRON_SECRET="production-cron-secret-min-32-chars-random"
